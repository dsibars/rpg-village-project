{
  "name": "rpg-village",
  "version": "1.0.0",
  "description": "A premium village management and hero progression game built with Vue 3.",
  "type": "module",
  "main": "infrastructure/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:debug": "vite build -m debug",
    "electron:run": "ELECTRON_RUN_AS_NODE= electron infrastructure/electron/main.js",
    "electron:package": "ELECTRON_RUN_AS_NODE= electron-forge package",
    "electron:make": "ELECTRON_RUN_AS_NODE= electron-forge make",
    "test": "node --test $(find tests/unit tests/behaviour -name '*.test.js')",
    "test:vue": "vitest run tests/vue/",
    "test:vue:watch": "vitest tests/vue/",
    "screenshots": "node scripts/screenshots/orchestrator.mjs",
    "screenshots:dry": "node scripts/screenshots/orchestrator.mjs --dry-run",
    "screenshots:audit": "node scripts/screenshots/audit.mjs",
    "combat:lab": "node scripts/combat-lab/runner.mjs",
    "combat:lab:full": "node scripts/combat-lab/runner.mjs --full"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "electron": "^41.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "vite": "^5.2.0",
    "vite-plugin-singlefile": "^2.0.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "vue": "^3.5.35"
  }
}
